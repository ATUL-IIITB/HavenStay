<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>
    <header>
        <h1> <img src="logo.png" alt="logo" id="plane"> Book Your Holiday Spot TODAY!! </h1>
        <h2> With Us</h2>
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="/listings">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="listings/new">Add Hotel</a>
                        </li>
                </div>
            </div>
        </nav>
    </header>

    <div class="alllists">
        
            <% for(listing of allListings){ %>
                <a href="/listings/<%=listing._id%>">
                <div class="card" style="width: 18rem;">
                    <img src="<%= listing.Image %>" class="card-img-top" alt="<%= listing.name %>">
                    <div class="card-body">
                        <h5 class="card-title">Card title</h5>
                        <p class="card-text"><%= listing.name %></p>
                    </div>
                </div>
                </a>
                <%}%>
        
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>