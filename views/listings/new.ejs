<% layout("/layouts/boilerplate.ejs") %>

<header>
    <h1><b>Fill the form to Register your Hotel</b></h1>
</header>

<form action="/listings" method="POST" class="needs-validation" novalidate>

    <div class="addDetails">
        <ul id="addNewForm">

            <li class="addNewForm">
                <label for="name">Name :</label>

                <input
                    type="text"
                    class="form-control"
                    name="listing[name]"
                    placeholder="Enter the Name of Villa"
                    required>

                <div class="invalid-feedback">
                    Please enter the hotel name.
                </div>
            </li>

            <li class="addNewForm">
                <label for="Image">Image URL :</label>

                <input
                    type="text"
                    class="form-control"
                    name="listing[Image]"
                    placeholder="Enter Image URL">

                <div class="valid-feedback">
                    Looks good!
                </div>
            </li>

            <li class="addNewForm">
                <label for="description">Description :</label>

                <textarea
                    class="form-control"
                    name="listing[description]"
                    placeholder="Enter description of the villa"
                    rows="5"
                    required></textarea>

                <div class="invalid-feedback">
                    Please provide a description.
                </div>
            </li>

            <li class="addNewForm">
                <label for="price">Price :</label>

                <input
                    type="number"
                    class="form-control"
                    name="listing[price]"
                    placeholder="Enter Price"
                    required>

                <div class="invalid-feedback">
                    Please enter a valid price.
                </div>
            </li>

            <li class="addNewForm">
                <label for="location">Location :</label>

                <input
                    type="text"
                    class="form-control"
                    name="listing[location]"
                    placeholder="Enter Location"
                    required>

                <div class="invalid-feedback">
                    Please enter the location.
                </div>
            </li>

            <li class="addNewForm text-center">
                <button type="submit" class="btn btn-primary">
                    Register Hotel
                </button>
            </li>

        </ul>
    </div>

</form>